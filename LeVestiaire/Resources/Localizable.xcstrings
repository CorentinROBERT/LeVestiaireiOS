    "" : {

    },
    "—" : {
      "comment" : "A placeholder text that indicates an empty bench slot.",
      "isCommentAutoGenerated" : true
    },
    "·" : {
      "comment" : "A period used to separate two related items.",
      "isCommentAutoGenerated" : true
    },
    "%@ %@" : {
      "comment" : "A label that shows the name of the home team and the name of the opponent team, separated by a \"vs.\"",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@"
          }
        }
      }
    },
    "%@ %lld" : {
      "comment" : "A label that displays the question number. The argument is the question number.",
