# Copie ce fichier vers ci-secrets.local.env (ignoré par git), remplis les valeurs,
# puis lance : ./Scripts/configure_github_secrets.sh

# --- App Store Connect API ---
# https://appstoreconnect.apple.com/access/integrations/api
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
# Chemin vers le fichier AuthKey_XXXXXX.p8 téléchargé une seule fois
APP_STORE_CONNECT_KEY_PATH=

# --- Signature iOS ---
# Certificat Apple Distribution exporté depuis Trousseaux d'accès (.p12)
IOS_DISTRIBUTION_CERTIFICATE_PATH=
IOS_DISTRIBUTION_CERTIFICATE_PASSWORD=

# Profil App Store pour com.corentin.robert.LeVestaire (.mobileprovision)
IOS_PROVISIONING_PROFILE_PATH=
# Nom exact du profil (visible dans developer.apple.com ou Xcode)
# Laisse vide pour détection automatique depuis le fichier .mobileprovision
IOS_PROVISIONING_PROFILE_NAME=

# Mot de passe du trousseau temporaire utilisé par la CI (choisis une valeur forte)
KEYCHAIN_PASSWORD=

# Repo GitHub (optionnel)
GITHUB_REPOSITORY=CorentinROBERT/LeVestiaireiOS
